# Copy to .env and fill in. On Vercel, set these under
# Project → Settings → Environment Variables (do NOT commit real secrets).

# MongoDB connection string
MONGODB_URI=

# NextAuth — NEXTAUTH_URL is your site origin (e.g. https://themooncharm.com in prod)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (optional — enables "Continue with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gmail SMTP — required for the /contact form to deliver email (via Nodemailer)
# GMAIL_USER: the sending Gmail address (must EXACTLY match the account the
# App Password was created on — no extra prefixes)
GMAIL_USER=themooncharm26@gmail.com
# GMAIL_APP_PASSWORD: 16-char Google App Password (needs 2-Step Verification on)
GMAIL_APP_PASSWORD=
# Optional — recipient for submissions. Defaults to GMAIL_USER if left blank.
# e.g. set to info.themooncharm@gmail.com to deliver to the public inbox.
CONTACT_TO_EMAIL=
